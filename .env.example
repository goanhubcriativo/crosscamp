# ---------- Evento ----------
EVENT_NAME="Meu Evento"
EVENT_DESCRIPTION="Descrição curta do evento"
EVENT_DATE="2026-08-15 20:00"
EVENT_LOCATION="Local do evento"
# Preço único do ingresso, em reais (use ponto como separador decimal)
EVENT_PRICE="50.00"

# URL pública da aplicação (usada no webhook e nos links do ingresso)
# Em dev: http://localhost:3000 | Em produção: https://seu-app.vercel.app
APP_URL="http://localhost:3000"

# ---------- Banco de dados (libSQL / SQLite) ----------
# Dev local: arquivo. Produção (Vercel): use Turso -> libsql://...
DATABASE_URL="file:local.db"
# Só necessário no Turso (produção):
DATABASE_AUTH_TOKEN=""

# ---------- Asaas (gateway PIX) ----------
# sandbox (testes) ou production
ASAAS_ENV="sandbox"
# Chave de API do Asaas (Configurações -> Integrações -> API)
ASAAS_API_KEY=""
# Token secreto compartilhado do webhook (defina o mesmo valor no painel do Asaas)
ASAAS_WEBHOOK_TOKEN=""

# ---------- Painel do gestor ----------
ADMIN_USER="admin"
ADMIN_PASSWORD="troque-esta-senha"
# Segredo para assinar o cookie de sessão (use uma string longa e aleatória)
SESSION_SECRET="troque-por-uma-string-longa-e-aleatoria"

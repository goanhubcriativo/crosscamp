# ---------- Plataforma ----------
# URL pública da aplicação (usada nos links de ingresso e no webhook)
# Em dev: http://localhost:3000 | Em produção: https://crosscamp-alpha.vercel.app
APP_URL="http://localhost:3000"

# ---------- Banco de dados (libSQL / SQLite) ----------
# Dev local: arquivo. Produção (Vercel): use Turso -> libsql://...
DATABASE_URL="file:local.db"
# Só necessário no Turso (produção):
DATABASE_AUTH_TOKEN=""

# ---------- Asaas ----------
# A CHAVE de API é definida por evento no painel admin (cada evento tem a sua).
# Aqui fica apenas o token compartilhado dos webhooks (o mesmo em toda conta Asaas).
ASAAS_WEBHOOK_TOKEN=""

# ---------- Painel do gestor ----------
ADMIN_USER="admin"
ADMIN_PASSWORD="troque-esta-senha"
# Segredo para assinar o cookie de sessão (string longa e aleatória)
SESSION_SECRET="troque-por-uma-string-longa-e-aleatoria"
